# Exemplo de .env — copie para .env e preencha. NÃO comite o .env real.

# ---- Banco (PostgreSQL) -----------------------------------------------------
DB_PASSWORD=troque-esta-senha

# ---- Roteamento de LLM + FAILOVER -------------------------------------------
# Primário: hub gpt-oss-120b. Em TIMEOUT / indisponibilidade do primário
# (timeout, conexão recusada, rate-limit, 5xx), o sistema faz FAILOVER
# automático para o provedor de fallback abaixo (Azure OpenAI).
LLM_PROVIDER=oss120b_http
LLM_GENERAL_PROVIDER=oss120b_http
LLM_SQL_PROVIDER=oss120b_http
LLM_FALLBACK_PROVIDER=azure
# Timeout POR CHAMADA de LLM no primário antes de cair para o fallback (s).
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=1

# ---- gpt-oss-120b HTTP (primário) -------------------------------------------
OSS120B_URL=https://hub-gpus.claro.com.br/gpt120/v1
OSS120B_MODEL=openai/gpt-oss-120b
OSS120B_API_KEY=not-needed

# ---- Azure OpenAI (FALLBACK) ------------------------------------------------
# Enquanto AZURE_OPENAI_API_KEY estiver vazio, o failover fica INATIVO e o app
# opera só com o primário (sem quebrar). Preencha os 4 valores para ativar.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://SEU-RECURSO.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
